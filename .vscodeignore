# Dependencies & caches
node_modules/**
webview/node_modules/**
webview/.npm-cache/**
.npm-cache/**
%CD%/**
.history/**
.vscode-test/**

# Sources (keep dist only)
src/**
webview/src/**
scripts/**
chrome-extension/**
chrome-extension/ui/**
release/**
webview/**

# Build artifacts
**/*.map
**/*.ts

# Tests (never publish)
dist/test/**
dist/test-node/**
dist/test-vscode/**
test/**

# 覆盖率 HTML 报告（vitest --coverage 等生成；勿打入 VSIX）
coverage/**
coverage-out/**

# 仓库元数据（扩展运行时不需要）
.gitignore

# Webview dev artifacts
dist-webview/regexpReplacer.dev.commands.json

# Dev-only configs
.vscode/**
eslint.config.js
cspell.json
tsconfig*.json

# README screenshots (README uses raw.githubusercontent.com URLs; omit from .vsix to shrink package)
images/**

# Docs
README.zh-CN.md
