{
  "manifest_version": 3,
  "name": "RegExp Replacer",
  "version": "0.0.1",
  "description": "在浏览器中打开 RegExp Replacer UI，用于测试替换规则并导入/导出配置。",
  "action": {
    "default_title": "RegExp Replacer",
    "default_icon": {
      "16": "icon/favicon.png",
      "32": "icon/favicon.png",
      "48": "icon/favicon.png",
      "128": "icon/favicon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon/favicon.png",
    "32": "icon/favicon.png",
    "48": "icon/favicon.png",
    "128": "icon/favicon.png"
  }
}

