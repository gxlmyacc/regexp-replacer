{
  "name": "regexp-replacer",
  "private": true,
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.2",
  "packageManager": "yarn@1.22.22",
  "publisher": "gxlmyacc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gxlmyacc/regexp-replacer"
  },
  "vsce": {
    "yarn": false
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon/favicon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "regexpReplacer.replaceInFile",
        "title": "%command.replaceInFile.title%",
        "category": "%command.category%",
        "icon": "icon/favicon.png"
      },
      {
        "command": "regexpReplacer.replaceInSelection",
        "title": "%command.replaceInSelection.title%",
        "category": "%command.category%",
        "icon": "icon/favicon.png"
      },
      {
        "command": "regexpReplacer.openCommandManager",
        "title": "%command.openCommandManager.title%",
        "category": "%command.category%",
        "icon": "icon/favicon.png"
      },
      {
        "command": "regexpReplacer.openRegExpUI",
        "title": "%command.openRegExpUI.title%",
        "category": "%command.category%",
        "icon": {
          "light": "icon/favicon.png",
          "dark": "icon/favicon.png"
        }
      }
    ],
    "submenus": [
      {
        "id": "regexpReplacer.editorTitleMenu",
        "label": "%submenu.editorTitle.label%",
        "icon": {
          "light": "icon/favicon.png",
          "dark": "icon/favicon.png"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "regexpReplacer.replaceInFile",
          "group": "regexpReplacer@1",
          "when": "resourceScheme =~ /^(file|untitled|vscode-notebook-cell|vscode-interactive-input)$/"
        },
        {
          "command": "regexpReplacer.replaceInSelection",
          "group": "regexpReplacer@2",
          "when": "editorHasSelection && resourceScheme =~ /^(file|untitled|vscode-notebook-cell|vscode-interactive-input)$/"
        }
      ],
      "editor/title": [
        {
          "submenu": "regexpReplacer.editorTitleMenu",
          "group": "navigation@100",
          "when": "editorIsOpen && config.regexpReplacer.ui.showIcon && config.regexpReplacer.ui.iconPlacement == 'editor' && resourceScheme =~ /^(file|untitled|vscode-notebook-cell|vscode-interactive-input)$/"
        }
      ],
      "regexpReplacer.editorTitleMenu": [
        {
          "command": "regexpReplacer.replaceInFile",
          "group": "regexpReplacer@1"
        },
        {
          "command": "regexpReplacer.replaceInSelection",
          "group": "regexpReplacer@2"
        },
        {
          "command": "regexpReplacer.openRegExpUI",
          "group": "regexpReplacer@3"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "regexpReplacer.ui.showIcon": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.ui.showIcon.description%"
        },
        "regexpReplacer.ui.iconPlacement": {
          "type": "string",
          "default": "editor",
          "enum": [
            "editor",
            "statusBarLeft",
            "statusBarRight"
          ],
          "enumDescriptions": [
            "%configuration.ui.iconPlacement.editor%",
            "%configuration.ui.iconPlacement.statusBarLeft%",
            "%configuration.ui.iconPlacement.statusBarRight%"
          ],
          "description": "%configuration.ui.iconPlacement.description%"
        },
        "regexpReplacer.commands": {
          "type": "array",
          "default": [],
          "description": "%configuration.commands.description%",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "rules"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "%configuration.commands.item.id%"
              },
              "title": {
                "type": "string",
                "description": "%configuration.commands.item.title%"
              },
              "description": {
                "type": "string",
                "description": "%configuration.commands.item.description%"
              },
              "rules": {
                "type": "array",
                "description": "%configuration.commands.item.rules%",
                "items": {
                  "type": "object",
                  "required": [
                    "find",
                    "replace",
                    "engine"
                  ],
                  "allOf": [
                    {
                      "if": {
                        "properties": {
                          "replaceMode": {
                            "const": "map"
                          }
                        }
                      },
                      "then": {
                        "properties": {
                          "engine": {
                            "const": "regex"
                          }
                        },
                        "required": [
                          "map"
                        ]
                      }
                    }
                  ],
                  "properties": {
                    "title": {
                      "type": "string",
                      "description": "%configuration.commands.item.rules.title%"
                    },
                    "enable": {
                      "type": "boolean",
                      "default": true,
                      "description": "%configuration.commands.item.rules.enable%"
                    },
                    "engine": {
                      "type": "string",
                      "enum": [
                        "regex",
                        "text",
                        "wildcard"
                      ],
                      "description": "%configuration.commands.item.rules.engine%"
                    },
                    "find": {
                      "type": "string",
                      "description": "%configuration.commands.item.rules.find%"
                    },
                    "replace": {
                      "type": "string",
                      "description": "%configuration.commands.item.rules.replace%"
                    },
                    "testText": {
                      "type": "string",
                      "description": "%configuration.commands.item.rules.testText%"
                    },
                    "replaceMode": {
                      "type": "string",
                      "enum": [
                        "template",
                        "map"
                      ],
                      "default": "template",
                      "description": "%configuration.commands.item.rules.replaceMode%"
                    },
                    "map": {
                      "type": "object",
                      "description": "%configuration.commands.item.rules.map%",
                      "required": [
                        "cases"
                      ],
                      "properties": {
                        "mode": {
                          "type": "string",
                          "enum": [
                            "text",
                            "regex"
                          ],
                          "default": "text",
                          "description": "%configuration.commands.item.rules.map.mode%"
                        },
                        "cases": {
                          "type": "array",
                          "minItems": 1,
                          "description": "%configuration.commands.item.rules.map.cases%",
                          "items": {
                            "type": "object",
                            "required": [
                              "find",
                              "replace"
                            ],
                            "properties": {
                              "find": {
                                "type": "string",
                                "description": "%configuration.commands.item.rules.map.cases.item.find%"
                              },
                              "replace": {
                                "type": "string",
                                "description": "%configuration.commands.item.rules.map.cases.item.replace%"
                              }
                            }
                          }
                        }
                      }
                    },
                    "flags": {
                      "type": "string",
                      "description": "%configuration.commands.item.rules.flags%"
                    },
                    "wildcardOptions": {
                      "type": "object",
                      "description": "%configuration.commands.item.rules.wildcardOptions%",
                      "properties": {
                        "dotAll": {
                          "type": "boolean",
                          "default": false,
                          "description": "%configuration.commands.item.rules.wildcardOptions.dotAll%"
                        }
                      }
                    },
                    "preCommands": {
                      "type": "array",
                      "description": "%configuration.commands.item.rules.preCommands%",
                      "items": {
                        "type": "string"
                      }
                    },
                    "postCommands": {
                      "type": "array",
                      "description": "%configuration.commands.item.rules.postCommands%",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "compile:test:vscode": "tsc -p tsconfig.test-vscode.json",
    "watch": "tsc -watch -p .",
    "bundle:extension": "node ./scripts/bundle-extension.mjs",
    "build:webview": "vite build -c webview/vite.config.ts",
    "build:webview:analyze": "vite build -c webview/vite.config.ts --mode analyze",
    "build:chrome:ui": "vite build -c webview/vite.chrome.config.ts",
    "build:chrome": "node ./scripts/build-chrome.mjs",
    "dev:webview": "vite -c webview/vite.config.ts",
    "dev": "node ./scripts/dev.mjs",
    "vscode:prepublish": "node ./scripts/vscode-prepublish.mjs",
    "package": "node ./scripts/package-vsix.mjs",
    "lint": "eslint .",
    "test": "npm run test:webview && npm run test:vscode && node ./dist/test-node/runTest.js",
    "test:webview": "vitest run -c test/webview/vitest.config.ts",
    "test:vscode": "node ./scripts/run-vscode-tests.mjs",
    "coverage": "npm run coverage:webview && npm run coverage:vscode",
    "coverage:webview": "vitest run -c test/webview/vitest.config.ts --coverage",
    "coverage:vscode": "node ./scripts/run-vscode-tests.mjs --coverage"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.39.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^16.14.62",
    "@types/react-dom": "^16.9.24",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "2.1.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "mocha": "^11.7.5",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "vite": "^8.0.10",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@eslint-community/regexpp": "^4.12.2",
    "@popperjs/core": "^2.11.8",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "regenerator-runtime": "^0.14.1",
    "use-modal-ref": "^0.1.6-alpha.3"
  }
}
