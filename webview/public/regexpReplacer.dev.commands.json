[
  {
    "id": "dev_sample_01",
    "title": {
      "en": "Demo: Prefix digits",
      "zh-CN": "Demo: 数字加前缀"
    },
    "description": {
      "en": "Add # before each run of digits.",
      "zh-CN": "把连续数字前面加上 #。"
    },
    "rules": [
      {
        "title": {
          "en": "Prefix digits",
          "zh-CN": "数字加前缀"
        },
        "engine": "regex",
        "find": "\\d+",
        "replace": "#$&",
        "testText": "a1 b22 c333",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_02",
    "title": {
      "en": "Demo: Text replace",
      "zh-CN": "Demo: 文本替换"
    },
    "description": {
      "en": "Replace foo with bar.",
      "zh-CN": "把 foo 替换为 bar。"
    },
    "rules": [
      {
        "engine": "text",
        "find": "foo",
        "replace": "bar"
      }
    ]
  },
  {
    "id": "dev_sample_03",
    "title": {
      "en": "Demo: Wildcard replace",
      "zh-CN": "Demo: 通配符替换"
    },
    "description": {
      "en": "Replace patterns like a*?b with X.",
      "zh-CN": "把 a*?b 这种模式替换为 X。"
    },
    "rules": [
      {
        "engine": "wildcard",
        "find": "a*?b",
        "replace": "X",
        "wildcardOptions": {
          "dotAll": false
        }
      }
    ]
  },
  {
    "id": "dev_sample_04",
    "title": {
      "en": "Demo: Trim trailing spaces",
      "zh-CN": "Demo: 去掉行尾空格"
    },
    "description": {
      "en": "Remove spaces and tabs at the end of each line.",
      "zh-CN": "删除每行末尾的空格与制表符。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "[\\t ]+$",
        "replace": "",
        "testText": "a  \n\tb\t\nc",
        "flags": "gm"
      }
    ]
  },
  {
    "id": "dev_sample_05",
    "title": {
      "en": "Demo: Normalize newlines (CRLF → LF)",
      "zh-CN": "Demo: 统一换行（CRLF -> LF）"
    },
    "description": {
      "en": "Convert Windows line breaks \\r\\n to \\n.",
      "zh-CN": "把 Windows 换行 \\r\\n 统一为 \\n。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "\\r\\n",
        "replace": "\\n",
        "testText": "line1\r\nline2\r\n",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_06",
    "title": {
      "en": "Demo: Collapse extra blank lines",
      "zh-CN": "Demo: 合并多余空行"
    },
    "description": {
      "en": "Compress 3+ consecutive blank lines to 2.",
      "zh-CN": "将连续 3 行及以上的空行压缩为 2 行。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "(?:\\r?\\n){3,}",
        "replace": "\\n\\n",
        "testText": "a\n\n\n\nb",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_07",
    "title": {
      "en": "Demo: camelCase to kebab-case",
      "zh-CN": "Demo: 驼峰转短横线"
    },
    "description": {
      "en": "Turn fooBarBaz into foo-bar-baz (simple demo).",
      "zh-CN": "把 fooBarBaz 转为 foo-bar-baz（仅演示简单规则）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "([a-z0-9])([A-Z])",
        "replace": "$1-$2",
        "testText": "fooBarBaz",
        "flags": "g"
      },
      {
        "engine": "regex",
        "find": "[A-Z]",
        "replace": "X",
        "testText": "fooBarBaz",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_08",
    "title": {
      "en": "Demo: Mask emails",
      "zh-CN": "Demo: 邮箱脱敏"
    },
    "description": {
      "en": "Mask user@example.com as u***@example.com.",
      "zh-CN": "把邮箱 user@example.com 脱敏为 u***@example.com。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "\\b([A-Za-z0-9])([A-Za-z0-9._%+-]*)(@[^\\s@]+)\\b",
        "replace": "$1***$3",
        "testText": "user@example.com admin.test+1@example.com",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_09",
    "title": {
      "en": "Demo: Quote JSON keys",
      "zh-CN": "Demo: JSON Key 加引号"
    },
    "description": {
      "en": "Turn {a:1, b:2} keys into {\"a\":1, \"b\":2} (simplified).",
      "zh-CN": "将 {a:1, b:2} 的 key 变为 {\"a\":1, \"b\":2}（简化版）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "(^|[,{\\s])([A-Za-z_][A-Za-z0-9_]*)(\\s*):",
        "replace": "$1\"$2\"$3:",
        "testText": "{a:1, b:2, foo_bar: 3}",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_10",
    "title": {
      "en": "Demo: Markdown link to text",
      "zh-CN": "Demo: Markdown 链接提取文本"
    },
    "description": {
      "en": "Replace [text](url) with text.",
      "zh-CN": "把 [text](url) 替换为 text。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
        "replace": "$1",
        "testText": "see [Doc](https://example.com) and [API](./api.md)",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_11",
    "title": {
      "en": "Demo: Space after comma",
      "zh-CN": "Demo: 逗号后补空格"
    },
    "description": {
      "en": "Turn a,b,c into a, b, c (does not handle newlines).",
      "zh-CN": "把 a,b,c 变为 a, b, c（不处理换行场景）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": ",(?!\\s)",
        "replace": ", ",
        "testText": "a,b,c",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_12",
    "title": {
      "en": "Demo: Strip HTML comments",
      "zh-CN": "Demo: 删除 HTML 注释"
    },
    "description": {
      "en": "Remove <!-- ... --> blocks (non-greedy).",
      "zh-CN": "移除 <!-- ... --> 注释块（非贪婪）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "<!--[\\s\\S]*?-->",
        "replace": "",
        "testText": "a<!-- c -->b",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_13",
    "title": {
      "en": "Demo: Unquote double-quoted strings",
      "zh-CN": "Demo: 提取双引号内容"
    },
    "description": {
      "en": "Turn \"abc\" into abc (simple escapes).",
      "zh-CN": "将 \"abc\" 变为 abc（支持转义的简化版）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "\"((?:\\\\\\\\.|[^\"\\\\\\\\])*)\"",
        "replace": "$1",
        "testText": "\"abc\" \"a\\\\\"b\"",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_14",
    "title": {
      "en": "Demo: Remove UTF-8 BOM",
      "zh-CN": "Demo: 去掉 UTF-8 BOM"
    },
    "description": {
      "en": "Remove leading \\uFEFF (BOM).",
      "zh-CN": "删除文本开头的 \\uFEFF（BOM）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "^\\uFEFF",
        "replace": "",
        "testText": "\uFEFFHello",
        "flags": ""
      }
    ]
  },
  {
    "id": "dev_sample_15",
    "title": {
      "en": "Demo: Comment out console.log",
      "zh-CN": "Demo: 批量注释掉 console.log"
    },
    "description": {
      "en": "Turn console.log(...) into // console.log(...) (per-line, simplified).",
      "zh-CN": "将 console.log(...) 变为 // console.log(...)（简化版，按行处理）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "^(\\s*)console\\.log\\((.*)\\)\\s*;?\\s*$",
        "replace": "$1// console.log($2);",
        "testText": "console.log(1);\n  console.log(foo, bar)",
        "flags": "gm"
      }
    ]
  },
  {
    "id": "dev_sample_16",
    "title": {
      "en": "Demo: Collapse blank lines after imports",
      "zh-CN": "Demo: 去掉 import 的未用空行"
    },
    "description": {
      "en": "Collapse multiple blank lines to one (useful after import blocks).",
      "zh-CN": "将连续空行压缩为单空行（常用于整理 import 区块）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "(?:\\r?\\n){3,}",
        "replace": "\\n\\n",
        "testText": "a\n\n\n\nb",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_17",
    "title": {
      "en": "Demo: Normalize quotes (' → \")",
      "zh-CN": "Demo: 统一引号（' -> \"）"
    },
    "description": {
      "en": "Replace single-quoted strings with double-quoted (simplified; no complex escapes).",
      "zh-CN": "把单引号字符串替换为双引号字符串（简化版，不处理复杂转义）。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "'([^'\\r\\n]*)'",
        "replace": "\"$1\"",
        "testText": "const a = 'x'; const b = 'y';",
        "flags": "g"
      }
    ]
  },
  {
    "id": "dev_sample_18",
    "title": {
      "en": "Demo: Path separators (\\\\ → /)",
      "zh-CN": "Demo: 路径分隔符（\\\\ -> /）"
    },
    "description": {
      "en": "Replace Windows path backslashes with forward slashes.",
      "zh-CN": "把 Windows 路径分隔符反斜杠替换为正斜杠。"
    },
    "rules": [
      {
        "engine": "regex",
        "find": "\\\\\\\\",
        "replace": "/",
        "testText": "C:\\\\Users\\\\me\\\\file.txt",
        "flags": "g"
      }
    ]
  }
]
